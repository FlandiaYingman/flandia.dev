{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "env": {
    "browser": true,
    "es6": true,
    "node": true
  },
  "ignorePatterns": [".next/**", "node_modules/**"],
  "plugins": ["import", "jsx-a11y", "nextjs", "react", "typescript"],
  "settings": {
    "next": {
      "rootDir": "."
    },
    "react": {
      "version": "19.2.4"
    }
  },
  "rules": {
    "import/no-unassigned-import": "off",
    "react/react-in-jsx-scope": "off"
  }
}
